    },
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": [],
      "targetBlank": true,
      "title": "MLflow tracking server",
      "tooltip": "Open the MLflow UI for the churn-drift experiment",
      "type": "link",
      "url": "http://localhost:5000/#/experiments/churn-drift"
    }
  ],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Maximum KS-statistic across the 8 features. Threshold 0.20 = drift SLO breach.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 3,
          "mappings": [],
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.15},
              {"color": "red", "value": 0.2}
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "mirador:churn_drift:ks_stat:max{model=\"customer-churn-mlp\"}",
          "legendFormat": "max KS-stat",
          "refId": "A"
        }
      ],
      "title": "Drift today — max across features",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "30-day error budget remaining for the drift SLO (target 99%).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 25},
              {"color": "green", "value": 75}
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "100 * (1 - (1 - slo:sli_error:ratio_rate1d{slo=\"churn-drift\"}) / (1 - slo:objective:ratio{slo=\"churn-drift\"}))",
          "legendFormat": "budget remaining",
          "refId": "A"
        }
      ],
      "title": "30-day error budget remaining",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Time since the last drift CronJob push. > 36 h fires the freshness alert.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 86400},
              {"color": "red", "value": 129600}
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "mirador:churn_drift:freshness_seconds",
          "legendFormat": "age",
          "refId": "A"
        }
      ],
      "title": "Drift series freshness",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Per-feature KS-statistic over time. The threshold band (0.20) is the SLO trigger.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "KS-statistic",
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "never",
            "thresholdsStyle": {"mode": "line+area"}
          },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "transparent", "value": null},
              {"color": "rgba(220, 38, 38, 0.18)", "value": 0.2}
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 6},
      "id": 4,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "mirador_churn_drift_ks_stat{model=\"customer-churn-mlp\"}",
          "legendFormat": "{{feature}}",
          "refId": "A"
        }
      ],
      "title": "Per-feature drift over time",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Burn-rate alert windows. Dotted = SLO objective (target 99%).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "burn rate",
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "never",
            "scaleDistribution": {"type": "log", "log": 10}
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "red", "value": null}]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 5,
      "options": {
        "legend": {"calcs": ["last", "max"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "slo:sli_error:ratio_rate1h{slo=\"churn-drift\"} / (1 - slo:objective:ratio{slo=\"churn-drift\"})",
          "legendFormat": "1h burn rate",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "slo:sli_error:ratio_rate6h{slo=\"churn-drift\"} / (1 - slo:objective:ratio{slo=\"churn-drift\"})",
          "legendFormat": "6h burn rate",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "slo:sli_error:ratio_rate1d{slo=\"churn-drift\"} / (1 - slo:objective:ratio{slo=\"churn-drift\"})",
          "legendFormat": "1d burn rate",
          "refId": "C"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "slo:sli_error:ratio_rate3d{slo=\"churn-drift\"} / (1 - slo:objective:ratio{slo=\"churn-drift\"})",
          "legendFormat": "3d burn rate",
          "refId": "D"
        }
      ],
      "title": "Burn rate (multi-window)",
      "type": "timeseries"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["mirador", "ml", "slo", "churn"],
  "templating": {"list": []},
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Customer Churn — model drift (Phase E)",
  "uid": "mirador-churn-drift",
  "version": 1,
  "weekStart": ""
}
