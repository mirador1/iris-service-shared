  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "SLO compliance over the last 30d. Green = budget remaining, red = breach.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "max": 100,
          "min": 95,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 99},
              {"color": "green", "value": 99.5}
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(1 - slo:current_burn_rate:ratio{sloth_id=\"mirador-service-availability\"}) * 100",
          "legendFormat": "Availability",
          "refId": "A"
        }
      ],
      "title": "Availability SLO (target 99%)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Latency p99 SLO compliance — % of requests served < 500ms over 30d.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "max": 100,
          "min": 95,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 99},
              {"color": "green", "value": 99.5}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdMarkers": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(1 - slo:current_burn_rate:ratio{sloth_id=\"mirador-service-latency-p99\"}) * 100",
          "legendFormat": "Latency p99",
          "refId": "A"
        }
      ],
      "title": "Latency SLO (target 99% < 500ms)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
