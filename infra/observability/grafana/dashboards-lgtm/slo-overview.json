        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(1 - slo:current_burn_rate:ratio{sloth_id=\"mirador-service-enrichment-success\"}) * 100",
          "legendFormat": "Enrichment success",
          "refId": "A"
        }
      ],
      "title": "Enrichment SLO (target 99.5%)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Error budget remaining as % of total monthly budget. 100% = full budget unused, 0% = budget exhausted.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "Budget remaining (%)",
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 2,
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"}
          },
          "max": 100,
          "min": -10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 25},
              {"color": "green", "value": 50}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 6},
      "id": 4,
      "options": {
        "legend": {"calcs": ["last", "min", "max"], "displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "(1 - slo:current_burn_rate:ratio{sloth_id=~\"mirador-service.*\"}) * 100",
          "legendFormat": "{{ sloth_slo }} ({{ sloth_service }})",
          "refId": "A"
        }
      ],
      "title": "Error budget remaining (30d window)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Burn rate × normal pace. ≥ 14.4 = budget exhausted in <2h ; ≥ 6 = exhausted in <1d ; ≥ 1 = on pace to exhaust within window.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "axisLabel": "Burn rate (× normal)",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "orange", "value": 6},
              {"color": "red", "value": 14.4}
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 15},
      "id": 5,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "slo:current_burn_rate:ratio{sloth_id=~\"mirador-service.*\"}",
          "legendFormat": "{{ sloth_slo }} ({{ sloth_service }})",
          "refId": "A"
        }
      ],
      "title": "Burn rate (current × normal pace)",
      "type": "timeseries"
